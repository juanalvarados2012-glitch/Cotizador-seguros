# Copia este archivo a .env y pon tu clave de Groq.
# Estas variables son del SERVIDOR (proxy /api/quote). NO se exponen al navegador.

# Obligatoria — consíguela en https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Opcional — modelo de Groq (por defecto: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile
