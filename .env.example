# Copia este archivo a .env y pon tu clave de Groq.
# Estas variables son del SERVIDOR (proxy /api/quote). NO se exponen al navegador.

# Obligatoria — consíguela en https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Opcional — modelo de Groq (por defecto: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Clerk (autenticación / login) ──────────────────────────────────────────
# La PUBLISHABLE key SÍ va al navegador, por eso DEBE empezar con VITE_.
# Consíguela en https://dashboard.clerk.com (API Keys).
VITE_CLERK_PUBLISHABLE_KEY=pk_...
# La SECRET key es del servidor; NO la pongas con prefijo VITE_ ni la expongas.
CLERK_SECRET_KEY=sk_...
