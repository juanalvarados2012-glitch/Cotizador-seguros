# Copia este archivo a .env y pon tu clave de Groq.
# Estas variables son del SERVIDOR (proxy /api/quote). NO se exponen al navegador.

# Obligatoria — consíguela en https://console.groq.com/keys
GROQ_API_KEY=gsk_...

# Opcional — modelo de Groq (por defecto: llama-3.3-70b-versatile)
GROQ_MODEL=llama-3.3-70b-versatile

# ─── Clerk (autenticación / login) ──────────────────────────────────────────
# La PUBLISHABLE key SÍ va al navegador, por eso DEBE empezar con VITE_.
# Consíguela en https://dashboard.clerk.com (API Keys).
VITE_CLERK_PUBLISHABLE_KEY=pk_...
# La SECRET key es del servidor; NO la pongas con prefijo VITE_ ni la expongas.
CLERK_SECRET_KEY=sk_...

# ─── Memoria compartida del equipo en la nube (opcional) ─────────────────────
# Si configuras una base Redis, la memoria de cada EMPRESA (Clerk Organization)
# se sincroniza entre todas las computadoras del equipo vía /api/kb.
# Sin estas variables la app funciona igual, pero la memoria queda solo-local.
#
# Opción A — Vercel KV / Upstash desde el Marketplace de Vercel (crea estos nombres):
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...
# Opción B — Upstash directo (https://console.upstash.com, plan gratis):
# UPSTASH_REDIS_REST_URL=https://...upstash.io
# UPSTASH_REDIS_REST_TOKEN=...
